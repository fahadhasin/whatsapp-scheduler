[Unit]
Description=WhatsApp Telegram Bridge Bot
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/whatsapp-scheduler/telegram-bridge
ExecStart=/home/YOUR_USER/whatsapp-scheduler/telegram-bridge/venv/bin/python bot.py
Restart=always
RestartSec=10
EnvironmentFile=/home/YOUR_USER/whatsapp-scheduler/telegram-bridge/.env

[Install]
WantedBy=multi-user.target
